{
    "name": "hexlet/code",
    "description": "Project Difference Calculator (PHP)",
    "license": "MIT",
    "authors": [
        {
            "name": "mikhaelHan",
            "email": "hancharuk270185@mail.ru"
        }
    ],
    "scripts": {
        "lint": "composer exec --verbose phpcs -- --standard=PSR12 src bin",
        "lint-fix": "composer exec --verbose phpcbf -- --standard=PSR12 src bin",
        "test": "composer exec --verbose phpunit tests",
        "coverage": "php -d xdebug.mode=coverage vendor/bin/phpunit tests --coverage-text"
    },
    "autoload": {
        "psr-4": {
            "Hexlet\\Code\\": "src/"
        },
        "files": [
        "src/Utils.php",
        "src/Differ.php"
    ]
    },
    "bin": [
        "bin/gendiff"
    ],
    "require": {
        "docopt/docopt": "^1.0",
        "symfony/yaml": "^8.0"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^4.0",
        "phpunit/phpunit": "^13.0"
    }
}
